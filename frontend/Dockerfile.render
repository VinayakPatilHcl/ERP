# Pre-built: just serve static files via nginx
# Build locally with `npm run build` before pushing
FROM nginx:alpine
COPY dist/ /usr/share/nginx/html
COPY nginx.conf.template /etc/nginx/templates/default.conf.template
ENV NGINX_ENVSUBST_FILTER="BACKEND_URL|PORT"
ENV BACKEND_URL=backend:8080
ENV PORT=10000
EXPOSE 10000
